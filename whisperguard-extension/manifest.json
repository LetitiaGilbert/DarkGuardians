{
  "manifest_version": 3,
  "name": "WhisperGuard",
  "version": "1.0",
  "description": "Detect malicious IPFS content using ZK + Blockchain",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "ethers.min.js",
        "poseidon-build/poseidon.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}